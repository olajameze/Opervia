generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js models ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ──────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isSuperAdmin  Boolean      @default(false)
  frozenAt      DateTime?
  totpSecret    String?
  totpEnabledAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  notifications Notification[]
  auditLogs     AuditLog[]
  invitesSent   TeamInvite[] @relation("InvitesSent")
}

enum Role {
  OWNER
  ADMIN
  DISPATCHER
  OPS_MANAGER
  TECH
  FREELANCER
  FINANCE
  VIEWER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

model Organization {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  subscriptionPlan     SubscriptionPlan?
  trialEndsAt          DateTime?
  frozenAt             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  memberships          Membership[]
  clients              Client[]
  projects             Project[]
  jobs                 Job[]
  equipment            Equipment[]
  equipmentAllocations EquipmentAllocation[]
  staffProfiles        StaffProfile[]
  freelancerProfiles   FreelancerProfile[]
  shifts               Shift[]
  assignments          Assignment[]
  logisticsEvents      LogisticsEvent[]
  invoices             Invoice[]
  payments             Payment[]
  notifications        Notification[]
  workflowRules        WorkflowRule[]
  auditLogs            AuditLog[]
  teamInvites          TeamInvite[]
  skillCatalog         SkillCatalog[]
  workforceDocuments   WorkforceDocument[]
  availabilityRequests AvailabilityRequest[]
}

model Membership {
  id             String       @id @default(cuid())
  role           Role         @default(VIEWER)
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model TeamInvite {
  id             String       @id @default(cuid())
  email          String
  role           Role         @default(VIEWER)
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String
  organizationId String
  createdAt      DateTime     @default(now())
  invitedBy      User         @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email, organizationId])
}

model Client {
  id             String   @id @default(cuid())
  name           String
  email          String?
  phone          String?
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects       Project[]
}

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String?
  status         String   @default("active")
  clientId       String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  client         Client?  @relation(fields: [clientId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobs           Job[]
}

enum JobStatus {
  DRAFT
  SCHEDULED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Job {
  id             String      @id @default(cuid())
  title          String
  description    String?
  status         JobStatus   @default(DRAFT)
  priority       JobPriority @default(MEDIUM)
  scheduledAt    DateTime?
  startsAt       DateTime?
  endsAt         DateTime?
  completedAt    DateTime?
  location       String?
  projectId      String?
  organizationId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project?    @relation(fields: [projectId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    Assignment[]
  shifts         Shift[]
  logisticsEvents LogisticsEvent[]
  equipmentAllocations EquipmentAllocation[]
  availabilityRequests AvailabilityRequest[]
}

enum EquipmentStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

model Equipment {
  id             String          @id @default(cuid())
  name           String
  sku            String?
  category       String?
  status         EquipmentStatus @default(AVAILABLE)
  totalQuantity  Int             @default(1)
  dailyRate      Float?
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  allocations    EquipmentAllocation[]

  @@index([organizationId, name])
}

model EquipmentAllocation {
  id             String    @id @default(cuid())
  equipmentId    String
  jobId          String?
  quantity       Int       @default(1)
  startDate      DateTime
  endDate        DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  equipment      Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  job            Job?      @relation(fields: [jobId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model StaffProfile {
  id             String   @id @default(cuid())
  name           String
  email          String?
  phone          String?
  location       String?
  skills         String[]
  certifications String[]
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shifts         Shift[]
  assignments    Assignment[]
  documents      WorkforceDocument[]
}

model FreelancerProfile {
  id             String   @id @default(cuid())
  name           String
  email          String?
  phone          String?
  location       String?
  skills         String[]
  dayRate        Float?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    Assignment[]
  documents      WorkforceDocument[]
  availabilityResponses AvailabilityResponse[]
}

model Shift {
  id             String   @id @default(cuid())
  staffProfileId String
  jobId          String?
  startTime      DateTime
  endTime        DateTime
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  job            Job?     @relation(fields: [jobId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Assignment {
  id                  String             @id @default(cuid())
  jobId               String
  staffProfileId      String?
  freelancerProfileId String?
  startTime           DateTime?
  endTime             DateTime?
  organizationId      String
  assignedAt          DateTime           @default(now())
  job                 Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  staffProfile        StaffProfile?      @relation(fields: [staffProfileId], references: [id])
  freelancerProfile   FreelancerProfile? @relation(fields: [freelancerProfileId], references: [id])
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum LogisticsStatus {
  PLANNED
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  DELAYED
}

model LogisticsEvent {
  id             String          @id @default(cuid())
  jobId          String
  status         LogisticsStatus @default(PLANNED)
  location       String?
  notes          String?
  occurredAt     DateTime        @default(now())
  organizationId String
  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id             String        @id @default(cuid())
  number         String
  amount         Float
  currency       String        @default("GBP")
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments       Payment[]
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id                    String        @id @default(cuid())
  amount                Float
  currency              String        @default("GBP")
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  invoiceId             String?
  organizationId        String
  createdAt             DateTime      @default(now())
  invoice               Invoice?      @relation(fields: [invoiceId], references: [id])
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  INFO
  WARNING
  ALERT
  SUCCESS
}

model Notification {
  id             String           @id @default(cuid())
  title          String
  message        String
  type           NotificationType @default(INFO)
  read           Boolean          @default(false)
  userId         String?
  organizationId String
  createdAt      DateTime         @default(now())
  user           User?            @relation(fields: [userId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum WorkflowTrigger {
  JOB_UNASSIGNED
  EQUIPMENT_LOW
  INVOICE_OVERDUE
  LOGISTICS_DELAYED
  SHIFT_CONFLICT
}

model WorkflowRule {
  id             String          @id @default(cuid())
  name           String
  trigger        WorkflowTrigger
  enabled        Boolean         @default(true)
  config         Json?
  organizationId String
  createdAt      DateTime        @default(now())
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  userId         String?
  organizationId String
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                 String   @id @default("default")
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  updatedAt          DateTime @updatedAt
}

model SkillCatalog {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model WorkforceDocument {
  id                  String             @id @default(cuid())
  label               String
  fileName            String
  mimeType            String
  blobUrl             String
  sizeBytes           Int
  organizationId      String
  staffProfileId      String?
  freelancerProfileId String?
  uploadedAt          DateTime           @default(now())
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffProfile        StaffProfile?      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  freelancerProfile   FreelancerProfile? @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([staffProfileId])
  @@index([freelancerProfileId])
}

enum AvailabilityResponseStatus {
  AVAILABLE
  UNAVAILABLE
}

model AvailabilityRequest {
  id             String   @id @default(cuid())
  jobId          String
  organizationId String
  token          String   @unique
  expiresAt      DateTime
  sentAt         DateTime @default(now())
  requiredSkills String[]
  message        String?
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses      AvailabilityResponse[]

  @@index([organizationId])
  @@index([jobId])
}

model AvailabilityResponse {
  id                  String                     @id @default(cuid())
  requestId           String
  freelancerProfileId String
  status              AvailabilityResponseStatus
  respondedAt         DateTime                   @default(now())
  request             AvailabilityRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  freelancerProfile   FreelancerProfile          @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@unique([requestId, freelancerProfileId])
}
