# Database
# Local dev: npm run db:migrate (creates/applies migrations)
# Production deploys: migrations run via scripts/vercel-build.sh (auto-baselines P3005)
# Optional manual run against prod: DATABASE_URL="postgresql://..." npm run db:baseline:production
#
# DATABASE_URL — used by the app at runtime (pooled URL is fine on Neon/Supabase/Vercel Postgres)
# DIRECT_URL   — non-pooled connection for Prisma Migrate (required if DATABASE_URL is pooled)
# On Vercel + Neon, DATABASE_URL_UNPOOLED is auto-used when DIRECT_URL is unset.
# For local dev, set DIRECT_URL to the same value as DATABASE_URL.
DATABASE_URL="postgresql://user:password@localhost:5432/opervia?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/opervia?schema=public"

# Auth.js
# Production: AUTH_URL=https://your-domain.com (must match deployed HTTPS URL)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe — use sk_live_ / live price IDs in production (see docs/STRIPE-SETUP.md)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."     # £99/month Starter plan (5 staff, 10 freelancers)
STRIPE_PRICE_PRO="price_..."         # £199/month Pro plan (10 staff, 20 freelancers)
STRIPE_PRICE_ENTERPRISE="price_..."  # £399/month Enterprise plan (50 staff, 100 freelancers)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_TEST_MODE="true"  # Show test-mode banner (optional)

# Analytics (loaded only after cookie consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Resend (password reset, team invites, contact form, signup verification)
# Create an API key at https://resend.com/api-keys — never commit the real value.
RESEND_API_KEY=""
# For testing: onboarding@resend.dev (only delivers to your Resend account email)
# Production: use a verified domain, e.g. Opervia <no-reply@send.yourdomain.com>
RESEND_FROM="onboarding@resend.dev"
# Optional: recipient for npm run email:test and new signup admin notifications
RESEND_TEST_TO="opervia@gmail.com"
# Optional: override signup notification recipient (defaults to RESEND_TEST_TO or support email)
OPERVIA_SIGNUP_NOTIFY_EMAIL="opervia@gmail.com"

# Cloudflare Turnstile (recommended in production — both keys required)
# Create keys at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# App — production: https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Legal (shown on Terms and Privacy pages)
LEGAL_ENTITY_NAME="JGDev"
LEGAL_ENTITY_ADDRESS="United Kingdom"
OPERVIA_SUPPORT_EMAIL="opervia@gmail.com"
OPERVIA_SALES_EMAIL="opervia@gmail.com"

# Upstash Redis (recommended for production rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Super admin (comma-separated emails with platform access)
SUPER_ADMIN_EMAILS="opervia@gmail.com,admin@opervia.com"
