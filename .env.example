# Database
DATABASE_URL="postgresql://user:password@localhost:5432/opervia?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (create GBP recurring prices in Stripe Dashboard)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."     # £99/month Starter plan (5 staff, 10 freelancers)
STRIPE_PRICE_PRO="price_..."         # £199/month Pro plan (10 staff, 20 freelancers)
STRIPE_PRICE_ENTERPRISE="price_..."  # £399/month Enterprise plan (50 staff, 100 freelancers)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Resend (password reset, team invites, contact form)
# Create an API key at https://resend.com/api-keys
# Replace re_xxxxxxxxx with your real key — never commit the real value.
RESEND_API_KEY="re_xxxxxxxxx"
# For testing: onboarding@resend.dev (only delivers to your Resend account email)
# Production: use a verified domain, e.g. Opervia <no-reply@send.yourdomain.com>
RESEND_FROM="onboarding@resend.dev"
# Optional: recipient for npm run email:test
RESEND_TEST_TO="opervia@gmail.com"
# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Super admin (comma-separated emails with platform access)
SUPER_ADMIN_EMAILS="opervia@gmail.com,admin@opervia.com"
