# Database
DATABASE_URL="postgresql://user:password@localhost:5432/opervia?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (create GBP recurring prices in Stripe Dashboard)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."  # £29/month Starter plan
STRIPE_PRICE_PRO="price_..."      # £59/month Pro plan
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Resend (for password reset + contact form delivery)
# Get an API key from https://resend.com — leave blank in dev to log to console.
RESEND_API_KEY=""
# Optional. Must be a verified Resend sender (e.g. "Opervia <no-reply@yourdomain.com>").
# Contact form submissions are always delivered TO opervia@gmail.com.
RESEND_FROM=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Super admin (comma-separated emails with platform access)
SUPER_ADMIN_EMAILS="opervia@gmail.com,admin@opervia.com"
